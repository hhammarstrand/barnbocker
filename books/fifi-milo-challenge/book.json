      "audio": null,
      "video": null
    },
    {
      "text": "Fifi and Milo see Bruno the Bear. Bruno is big and strong. 'Can you help us?' asks Fifi. Bruno smiles and nods.",
      "image": "http://hailuo-image-algeng-data-us.oss-us-east-1.aliyuncs.com/image_inference_output%2Ftalkie%2Fprod%2Fimg%2F2026-04-11%2Ffc2bd8be-488f-42b9-881c-f48cf7a93f0a_aigc.jpeg?Expires=1775931547&OSSAccessKeyId=LTAI5tRDTcyEYLLuBEpJRwCi&Signature=9A731vnncMC8URu6mgu7QVxeaoQ%3D",
      "audio": null,
      "video": null
